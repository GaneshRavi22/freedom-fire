# Copy this file to .env.local for local development.
# For staging/production, fill in .env.staging / .env.production respectively.
# Never commit any .env file with real values.
#
# APP_ENV controls the app name and is set automatically by npm scripts and EAS:
#   development → "FreedomFire (dev)"    (default when running locally)
#   preview     → "FreedomFire (staging)"  (EAS preview channel / develop branch)
#   production  → "FreedomFire"            (EAS production channel / main branch)
#
# APP_ENV=development  # optional override; defaults to "development" locally

# ── Expo client (bundled into the app at build time) ─────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Get from: Sentry → Project Settings → Client Keys → DSN
EXPO_PUBLIC_SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0

# ── Build-time secrets ────────────────────────────────────────────────────────
# Used by the Sentry Expo plugin to upload source maps during production builds.
# Get from: Sentry → Settings → Auth Tokens
# SENTRY_AUTH_TOKEN=sntryu_...

# ── Supabase Edge Function secrets ────────────────────────────────────────────
# These are NOT set here — they are injected into Edge Functions at runtime.
# Set them with: supabase secrets set KEY=value
# ANTHROPIC_API_KEY=sk-ant-api03-...
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# GITHUB_TOKEN=ghp_...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
